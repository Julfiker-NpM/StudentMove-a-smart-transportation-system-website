generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  phone              String         @default("")
  studentId          String         @default("") @unique
  university         String         @default("")
  passwordHash       String         @default("")
  emailVerified      Boolean        @default(false)
  preferredLanguage  String         @default("en")
  notifyDelay        Boolean        @default(true)
  notifyOffer        Boolean        @default(true)
  notifySystem       Boolean        @default(true)
  role               UserRole       @default(STUDENT)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  subscriptions      Subscription[]
  feedbacks          Feedback[]
}

model RouteSuggestion {
  id            String   @id @default(cuid())
  origin        String
  destination   String
  recommendedBy String
  rankScore     Int
  createdAt     DateTime @default(now())
}

model Subscription {
  id         String             @id @default(cuid())
  userId     String
  plan       SubscriptionPlan
  status     SubscriptionStatus @default(PENDING)
  amountBdt  Int
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  audience  String   @default("all")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Feedback {
  id         String         @id @default(cuid())
  userId     String
  category   FeedbackCategory @default(SUGGESTION)
  subject    String
  comment    String
  status     FeedbackStatus @default(OPEN)
  adminReply String?
  createdAt  DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  STUDENT
  DRIVER
  ADMIN
}

enum SubscriptionPlan {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
}

enum FeedbackCategory {
  BUG
  SUGGESTION
  COMPLAINT
}

enum FeedbackStatus {
  OPEN
  RESOLVED
}
